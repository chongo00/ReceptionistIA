PORT=4000

# Public service URL (ngrok locally / domain on Azure)
# Required for Azure neural TTS so clients can access /tts/*.mp3
PUBLIC_BASE_URL=

# BlindsBook API
BLINDSBOOK_API_BASE_URL=http://localhost:3000
BLINDSBOOK_API_TOKEN=token_o_jwt_de_servicio

# Alternative (dev): auto-login via POST /auth/login if BLINDSBOOK_API_TOKEN is not set
BLINDSBOOK_LOGIN_EMAIL=
BLINDSBOOK_LOGIN_PASSWORD=

# ============================
# AZURE SPEECH (STT + TTS)
# ============================
# Create a Speech resource in Azure → Keys and Endpoint
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# TTS voices — female voices to match "Sara/Sarah" receptionist persona
# See: https://learn.microsoft.com/azure/ai-services/speech-service/language-support?tabs=tts
AZURE_TTS_VOICE_ES=es-MX-DaliaNeural
AZURE_TTS_VOICE_EN=en-US-JennyNeural

# ============================
# AZURE OPENAI (PRIMARY LLM)
# ============================
# Create an "Azure OpenAI" resource → Deploy a model (gpt-4o-mini recommended)
# Endpoint: https://YOUR-RESOURCE.openai.azure.com
# API Key: found under "Keys and Endpoint"
# Deployment: the name you gave the deployed model
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-10-21

# ============================
# PHONE → COMPANY MAPPING (MULTI-TENANT)
# ============================
# Phone numbers to companies mapping (JSON)
# Format: {"+15550000001":{"companyId":387}}
# Each entry can also include email/password for auto-login per company
PHONE_TO_COMPANY_MAP=

# ============================
# VOICE SIMULATOR (dev only)
# ============================
# Serves /test pages (voice-test-v2.html) for local testing.
# MUST be false in production to avoid exposing the simulator publicly.
# Default: true (enabled for local development)
VOICE_SIMULATOR_ENABLED=true

# ============================
# AZURE VOICE LIVE API (optional) — STT+TTS para llamadas de voz
# ============================
# Requires an Azure AI Services (Microsoft Foundry) resource.
# This is DIFFERENT from AZURE_SPEECH_KEY (that's Speech SDK).
# Models are fully managed — no deployment needed in Azure OpenAI.
# Portal: https://portal.azure.com/#create/Microsoft.CognitiveServicesSpeechServices
# Endpoint: https://YOUR-RESOURCE.cognitiveservices.azure.com
# Key: found under "Keys and Endpoint"
VOICE_LIVE_ENDPOINT=
VOICE_LIVE_API_KEY=
VOICE_LIVE_MODEL=gpt-5-mini
VOICE_LIVE_API_VERSION=2025-10-01

# ============================
# VOICE BACKEND SELECTOR
# ============================
# "local" = Azure Speech SDK STT+TTS (current stack)
# "voice_live" = Azure Voice Live API (STT+TTS+VAD via WebSocket)
# Default: local
VOICE_BACKEND=local

# ============================
# LANGUAGE
# ============================
# Default language for new calls. The system starts in this language
# and auto-detects the customer's language from their first utterance.
# Supported: en (English), es (Spanish). Default: en
DEFAULT_LANGUAGE=en

# ============================
# TURN-TAKING & NATURALNESS
# ============================
# Responsiveness: 0 = very patient, 1 = instant reply (default: 0.7)
TURN_RESPONSIVENESS=0.7
# Interruption sensitivity: 0 = never interrupt, 1 = instant barge-in (default: 0.5)
INTERRUPTION_SENSITIVITY=0.5
# Silence (ms) before Sara sends a nudge reminder (default: 8000)
REMINDER_TRIGGER_MS=8000
# Enable automatic "uh-huh" / "ajá" backchanneling (default: true)
ENABLE_BACKCHANNELING=true

# ============================
# LIVEKIT (optional WebRTC transport)
# ============================
# When configured, voice sessions use WebRTC via LiveKit instead of raw WebSocket.
# This provides lower latency, better NAT traversal, and echo cancellation.
# Install: npm install livekit-server-sdk
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_WS_URL=
